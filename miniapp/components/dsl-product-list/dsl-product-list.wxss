/* components/dsl-product-list/dsl-product-list.wxss — 商品列表组件样式 */

.dsl-product-list {
  width: 100%;
  padding: 20rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.dsl-product-list__section-title {
  margin-bottom: 16rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 600;
}

.dsl-product-list__grid {
  display: grid;
  gap: 16rpx;
}

.dsl-product-list__item {
  background-color: #ffffff;
  overflow: hidden;
  border: 1rpx solid #edf1f7;
  box-shadow: none;
}

.dsl-product-list__item-image {
  width: 100%;
  height: 184rpx;
  display: block;
}

.dsl-product-list__item-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 184rpx;
  background: #f1f5fb;
  font-size: 60rpx;
}

.dsl-product-list__item-info {
  padding: 12rpx;
}

.dsl-product-list__item-name {
  font-size: 24rpx;
  color: #333333;
  line-height: 1.4;
  height: auto;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dsl-product-list__item-tag {
  display: inline-flex;
  margin-top: 8rpx;
  padding: 2rpx 12rpx;
  background-color: #fff1f0;
  border-radius: 4rpx;
}

.dsl-product-list__item-tag-text {
  font-size: 20rpx;
  color: #ff4d4f;
}

.dsl-product-list__item-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 12rpx;
}

.dsl-product-list__item-price {
  display: flex;
  align-items: baseline;
}

.dsl-product-list__item-price-symbol {
  font-size: 22rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.dsl-product-list__item-price-value {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 600;
  margin-left: 2rpx;
}

.dsl-product-list__item-sales {
  font-size: 20rpx;
  color: #999999;
}

.dsl-product-list__empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.dsl-product-list__empty-text {
  font-size: 26rpx;
  color: #999999;
}
