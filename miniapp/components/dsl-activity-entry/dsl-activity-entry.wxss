/* components/dsl-activity-entry/dsl-activity-entry.wxss — 活动入口组件样式 */

.dsl-activity-entry {
  width: 100%;
}

.dsl-activity-entry__card {
  position: relative;
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

.dsl-activity-entry__image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.dsl-activity-entry__info {
  padding: 20rpx 24rpx;
}

.dsl-activity-entry__title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  display: block;
}

.dsl-activity-entry__subtitle {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.dsl-activity-entry__countdown {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.dsl-activity-entry__countdown-label {
  font-size: 22rpx;
  color: #999999;
  margin-right: 12rpx;
}

.dsl-activity-entry__countdown-time {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.dsl-activity-entry__list {
  width: 100%;
}

.dsl-activity-entry__list .dsl-activity-entry__card:last-child {
  margin-bottom: 0;
}
