/* pages/activity-detail/activity-detail.wxss — 活动详情页样式 */

.activity-detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== 加载状态 ========== */
.loading-area {
  text-align: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 活动封面 ========== */
.detail-cover {
  height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.detail-cover-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.detail-cover-type {
  padding: 6rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 24rpx;
  border-radius: 24rpx;
}

/* ========== 基本信息 ========== */
.detail-section {
  background-color: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 38rpx;
  color: #333;
  font-weight: 700;
  margin-bottom: 20rpx;
  display: block;
}

.detail-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.detail-info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  width: 36rpx;
  text-align: center;
}

.info-text {
  font-size: 28rpx;
  color: #666;
}

/* ========== 进度条 ========== */
.detail-progress {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #20b7ff);
  border-radius: 6rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 600;
}

/* ========== 活动介绍 ========== */
.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 700;
  margin-bottom: 16rpx;
  display: block;
}

.section-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

/* ========== 报名表单 ========== */
.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* ========== 场次选择 ========== */
.session-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.session-item {
  padding: 16rpx 28rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s;
}

.session-item.active {
  background-color: #ff4d4f;
}

.session-item.active .session-name {
  color: #fff;
}

.session-name {
  font-size: 26rpx;
  color: #333;
}

.session-status {
  font-size: 20rpx;
  color: #ff4d4f;
  background-color: #fff0f0;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
}

/* ========== 已满提示 ========== */
.full-notice {
  padding: 60rpx 32rpx;
  text-align: center;
}

.full-notice-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 底部提交栏 ========== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.submit-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1890ff, #20b7ff);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 14rpx rgba(23, 105, 255, 0.3);
}

.submit-btn.disabled {
  background-color: #ccc;
  box-shadow: none;
}
