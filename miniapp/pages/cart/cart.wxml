<!-- pages/cart/cart.wxml — 购物车页面 -->
<view class="cart-page">
  <!-- 购物车列表 -->
  <view class="cart-list" wx:if="{{!isEmpty}}">
    <view
      wx:for="{{cartList}}"
      wx:key="id"
      class="cart-item"
    >
      <!-- 选中框 -->
      <view
        class="item-check {{item.selected ? 'checked' : ''}}"
        data-index="{{index}}"
        bindtap="onItemSelect"
      >
        <text wx:if="{{item.selected}}" class="check-mark">&#10003;</text>
      </view>

      <!-- 商品图片 -->
      <image
        class="item-image"
        src="{{item.image || item.cover_url || item.product_image}}"
        mode="aspectFill"
        data-id="{{item.product_id}}"
        bindtap="onProductTap"
      />

      <!-- 商品信息 -->
      <view class="item-info">
        <text class="item-name">{{item.name || item.product_name}}</text>
        <text class="item-sku" wx:if="{{item.sku_name}}">规格: {{item.sku_name}}</text>
        <view class="item-bottom">
          <text class="item-price">&#165;{{item.price}}</text>
          <view class="item-quantity">
            <view
              class="qty-btn {{item.quantity <= 1 ? 'disabled' : ''}}"
              data-index="{{index}}"
              bindtap="onQuantityMinus"
            >-</view>
            <text class="qty-num">{{item.quantity}}</text>
            <view
              class="qty-btn"
              data-index="{{index}}"
              bindtap="onQuantityPlus"
            >+</view>
          </view>
        </view>
      </view>

      <!-- 删除按钮 -->
      <view
        class="item-delete"
        data-index="{{index}}"
        bindtap="onItemDelete"
      >&#10005;</view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty && !loading}}">
    <image class="empty-state__icon" src="/images/empty-cart.png" mode="aspectFit" />
    <text class="empty-state__text">购物车空空如也</text>
    <view class="empty-btn" bindtap="onGoShopping">去逛逛</view>
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar" wx:if="{{!isEmpty}}">
    <view class="select-all" bindtap="onSelectAll">
      <view class="item-check {{isAllSelected ? 'checked' : ''}}">
        <text wx:if="{{isAllSelected}}" class="check-mark">&#10003;</text>
      </view>
      <text class="select-all-text">全选</text>
    </view>
    <view class="total-info">
      <text class="total-label">合计:</text>
      <text class="total-price">&#165;{{selectedPrice}}</text>
    </view>
    <view
      class="checkout-btn {{selectedCount === 0 ? 'disabled' : ''}}"
      bindtap="onCheckout"
    >
      结算{{selectedCount > 0 ? '(' + selectedCount + ')' : ''}}
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-page" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
