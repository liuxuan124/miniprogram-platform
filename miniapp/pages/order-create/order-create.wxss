/* pages/order-create/order-create.wxss — 订单创建页样式 */

.order-create-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== 收货地址 ========== */
.address-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.address-section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: repeating-linear-gradient(
    90deg,
    #ff4d4f 0,
    #ff4d4f 20rpx,
    #ffa940 20rpx,
    #ffa940 40rpx
  );
}

.address-card {
  display: flex;
  align-items: center;
}

.address-icon {
  margin-right: 16rpx;
}

.address-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.address-info {
  flex: 1;
}

.address-name-phone {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-right: 16rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.address-arrow {
  font-size: 24rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.address-empty {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 商品列表 ========== */
.goods-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.goods-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.goods-sku {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 700;
}

.goods-qty {
  font-size: 24rpx;
  color: #999;
}

/* ========== 备注 ========== */
.remark-section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.remark-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}

.remark-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: #333;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
}

/* ========== 价格汇总 ========== */
.price-summary {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
}

.total-row {
  border-top: 1rpx solid #eee;
  padding-top: 16rpx;
  margin-top: 8rpx;
}

.total-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 700;
}

/* ========== 底部提交栏 ========== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  height: 100rpx;
  background-color: #fff;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.bottom-total {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.bottom-total-label {
  font-size: 28rpx;
  color: #333;
}

.bottom-total-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: 700;
  margin-left: 8rpx;
}

.submit-btn {
  padding: 0 64rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
}

.submit-btn.disabled {
  background-color: #ccc;
}