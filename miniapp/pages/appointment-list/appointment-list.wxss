/* pages/appointment-list/appointment-list.wxss — 预约服务列表样式 */

.appointment-list-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* ========== 搜索栏 ========== */
.search-bar {
  padding: 16rpx 24rpx;
  background-color: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx;
}

/* ========== 我的预约入口 ========== */
.my-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.my-entry-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.my-entry-arrow {
  font-size: 24rpx;
  color: #ccc;
}

/* ========== 服务列表 ========== */
.service-list {
  padding: 0 24rpx;
}

.service-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  padding: 20rpx;
}

.service-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.service-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.service-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
}

.service-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 12rpx;
}

.service-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 700;
}

.price-symbol {
  font-size: 24rpx;
}

.service-duration {
  font-size: 24rpx;
  color: #999;
}

/* ========== 加载状态 ========== */
.loading-area {
  text-align: center;
  padding: 32rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-state__icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-state__text {
  font-size: 28rpx;
  color: #999;
}
