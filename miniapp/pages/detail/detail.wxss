/* pages/detail/detail.wxss — 通用详情页样式 */

.detail-page {
  min-height: 100vh;
}

.detail-page__cover {
  width: 100%;
  height: 500rpx;
  display: block;
}

.detail-page__info {
  margin: 24rpx;
}

.detail-page__title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
  line-height: 1.4;
  display: block;
}

.detail-page__price {
  display: flex;
  align-items: baseline;
  margin-top: 16rpx;
}

.detail-page__price-symbol {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.detail-page__price-value {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: 700;
  margin-left: 4rpx;
}

.detail-page__date {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
  display: block;
}

.detail-page__content {
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333333;
}

.retry-btn {
  width: 320rpx;
  margin-top: 32rpx;
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
}
