<!--pages/index/index.wxml — 首页（动态渲染引擎）-->
<view class="page-wrapper" style="background-color: {{backgroundColor}};">
  <!-- 加载状态 -->
  <loading wx:if="{{loading}}" />

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="empty-state">
    <image class="empty-state__icon" src="/images/empty.png" mode="aspectFit" />
    <text class="empty-state__text">{{error}}</text>
    <view class="retry-btn btn-primary mt-24" bindtap="onRetry">重新加载</view>
  </view>

  <!-- 正常渲染 -->
  <view wx:else class="index-page">
    <!-- 动态渲染组件列表 -->
    <block wx:for="{{components}}" wx:key="id">
      <dsl-renderer
        component="{{item}}"
        bind:componentevent="handleComponentEvent"
      />
    </block>

    <!-- 触底加载状态 -->
    <view class="index-page__loadmore" wx:if="{{globalConfig.reach_bottom_load}}">
      <loading
        wx:if="{{loadingMore}}"
        text="加载更多..."
      />
      <text
        wx:elif="{{!hasMore && components.length > 0}}"
        class="index-page__loadmore-text"
      >— 没有更多了 —</text>
    </view>
  </view>
</view>
