/* pages/sign-in/sign-in.wxss — 每日签到页面样式 */

.sign-in-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* ========== 签到头部 ========== */
.sign-header {
  position: relative;
  overflow: hidden;
}

.sign-header__bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
}

.sign-header__content {
  position: relative;
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sign-header__title {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 700;
}

.sign-header__subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.sign-header__days {
  display: flex;
  align-items: baseline;
  margin-top: 32rpx;
}

.sign-days-num {
  font-size: 80rpx;
  color: #ffffff;
  font-weight: 800;
  line-height: 1;
}

.sign-days-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 12rpx;
}

/* ========== 本周签到日历 ========== */
.week-calendar {
  margin: -24rpx 24rpx 24rpx;
  position: relative;
  z-index: 1;
}

.week-calendar__title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.week-calendar__days {
  display: flex;
  justify-content: space-between;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.week-day__label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.week-day__circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

/* 已签到 */
.week-day.signed .week-day__circle {
  background-color: #ff4757;
}

.week-day__check {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 700;
}

/* 今天 */
.week-day.today .week-day__label {
  color: #ff4757;
  font-weight: 600;
}

.week-day.today .week-day__circle {
  border: 3rpx solid #ff4757;
  background-color: #fff;
}

.week-day__today-dot {
  font-size: 20rpx;
  color: #ff4757;
}

/* 已过未签到 */
.week-day.missed .week-day__circle {
  background-color: #eee;
}

/* 未来 */
.week-day.future .week-day__circle {
  background-color: #f5f5f5;
}

/* ========== 签到按钮 ========== */
.sign-action {
  padding: 32rpx 24rpx;
}

.sign-btn {
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 71, 87, 0.3);
}

.sign-btn:active {
  opacity: 0.85;
}

.sign-btn--done {
  background: #d9d9d9;
  box-shadow: none;
}

.sign-btn--loading {
  opacity: 0.7;
}

/* ========== 签到规则 ========== */
.sign-rules {
  margin: 0 24rpx 24rpx;
}

.sign-rules__title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sign-rules__list {
  padding-left: 8rpx;
}

.sign-rules__item {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.sign-rules__dot {
  color: #ff4757;
  margin-right: 12rpx;
  flex-shrink: 0;
}

/* ========== 积分记录入口 ========== */
.points-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 32rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.points-entry__text {
  font-size: 28rpx;
  color: #333;
}

.points-entry__arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #ccc;
  border-right: 3rpx solid #ccc;
  transform: rotate(45deg);
}
