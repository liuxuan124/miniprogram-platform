/* pages/appointment-book/appointment-book.wxss — 预约下单页样式 */

.appointment-book-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== 服务信息 ========== */
.service-section {
  display: flex;
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.service-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.service-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.service-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.service-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 700;
  margin-top: 8rpx;
}

.price-symbol {
  font-size: 24rpx;
}

.service-duration {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ========== 通用 Section ========== */
.section {
  background-color: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* ========== 日期选择 ========== */
.date-scroll {
  white-space: nowrap;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  background-color: #f5f5f5;
  transition: all 0.2s;
}

.date-item.active {
  background-color: #ff4d4f;
}

.date-item.disabled {
  opacity: 0.4;
}

.date-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.date-item.active .date-label {
  color: #fff;
}

.date-weekday {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.date-item.active .date-weekday {
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 时段选择 ========== */
.slots-grid {
  display: flex;
  flex-wrap: wrap;
}

.slot-item {
  width: calc(33.33% - 12rpx);
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
  position: relative;
}

.slot-item:nth-child(3n) {
  margin-right: 0;
}

.slot-item.active {
  background-color: #ff4d4f;
}

.slot-item.unavailable {
  opacity: 0.5;
}

.slot-time {
  font-size: 24rpx;
  color: #333;
}

.slot-item.active .slot-time {
  color: #fff;
}

.slot-item.unavailable .slot-time {
  color: #999;
}

.slot-status {
  font-size: 18rpx;
  color: #ff4d4f;
  margin-top: 2rpx;
}

.slots-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
}

.slots-empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 联系信息表单 ========== */
.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* ========== 底部提交栏 ========== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.submit-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.submit-btn.disabled {
  background-color: #ccc;
}
