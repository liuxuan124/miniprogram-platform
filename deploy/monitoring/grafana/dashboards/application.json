{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "微信小程序多场景搭建与运营系统 — 应用监控仪表盘",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "JVM 指标",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"miniapp-backend\", area=\"heap\"}",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"miniapp-backend\", area=\"heap\"}",
          "legendFormat": "Heap Max",
          "refId": "B"
        },
        {
          "expr": "jvm_memory_used_bytes{application=\"miniapp-backend\", area=\"nonheap\"}",
          "legendFormat": "Non-Heap Used",
          "refId": "C"
        }
      ],
      "title": "JVM 内存使用",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"miniapp-backend\"}",
          "legendFormat": "Live Threads",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"miniapp-backend\"}",
          "legendFormat": "Daemon Threads",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"miniapp-backend\"}",
          "legendFormat": "Peak Threads",
          "refId": "C"
        }
      ],
      "title": "JVM 线程数",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{application=\"miniapp-backend\"}[5m])",
          "legendFormat": "{{action}} GC Rate",
          "refId": "A"
        }
      ],
      "title": "GC 频率",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "title": "API 延迟",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max", "min"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"miniapp-backend\"}[5m])) by (le, uri))",
          "legendFormat": "P50 {{uri}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"miniapp-backend\"}[5m])) by (le, uri))",
          "legendFormat": "P95 {{uri}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"miniapp-backend\"}[5m])) by (le, uri))",
          "legendFormat": "P99 {{uri}}",
          "refId": "C"
        }
      ],
      "title": "API 响应延迟 (P50/P95/P99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"miniapp-backend\", status=~\"2..\"}[5m])) by (uri)",
          "legendFormat": "成功 {{uri}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"miniapp-backend\", status=~\"5..\"}[5m])) by (uri)",
          "legendFormat": "失败 {{uri}}",
          "refId": "B"
        }
      ],
      "title": "API 请求速率",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 8,
      "title": "错误率",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 19 },
      "id": 9,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"miniapp-backend\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"miniapp-backend\"}[5m]))",
          "legendFormat": "5xx Error Rate",
          "refId": "A"
        }
      ],
      "title": "5xx 错误率",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 19 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"miniapp-backend\", status=~\"4..\"}[5m])) by (uri, status)",
          "legendFormat": "{{status}} {{uri}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"miniapp-backend\", status=~\"5..\"}[5m])) by (uri, status)",
          "legendFormat": "{{status}} {{uri}}",
          "refId": "B"
        }
      ],
      "title": "错误请求分布",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 11,
      "title": "数据库连接池",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"miniapp-backend\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"miniapp-backend\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_max{application=\"miniapp-backend\"}",
          "legendFormat": "Max",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"miniapp-backend\"}",
          "legendFormat": "Pending",
          "refId": "D"
        }
      ],
      "title": "HikariCP 连接池状态",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_creation_seconds_sum{application=\"miniapp-backend\"} / hikaricp_connections_creation_seconds_count{application=\"miniapp-backend\"}",
          "legendFormat": "Avg Creation Time",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_usage_seconds_sum{application=\"miniapp-backend\"} / hikaricp_connections_usage_seconds_count{application=\"miniapp-backend\"}",
          "legendFormat": "Avg Usage Time",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_acquire_seconds_sum{application=\"miniapp-backend\"} / hikaricp_connections_acquire_seconds_count{application=\"miniapp-backend\"}",
          "legendFormat": "Avg Acquire Time",
          "refId": "C"
        }
      ],
      "title": "连接池延迟",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
