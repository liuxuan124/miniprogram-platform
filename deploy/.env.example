# ============================================================================
# 微信小程序多场景搭建与运营系统 — 环境变量模板
# ============================================================================
# 使用方法:
#   cp .env.example .env
#   编辑 .env 修改为实际值
# ============================================================================

# ── MySQL 配置 ────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=miniapp
MYSQL_USER=miniapp
MYSQL_PASSWORD=miniapp123456
MYSQL_PORT=3306

# ── Redis 配置 ────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis123456
REDIS_PORT=6379

# ── JWT 配置 ──────────────────────────────────────────────────────────────
# 生产环境务必修改为强随机字符串!
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=86400000

# ── 微信小程序配置 ────────────────────────────────────────────────────────
WX_MINIAPP_APPID=
WX_MINIAPP_SECRET=

# ── 微信支付配置 ──────────────────────────────────────────────────────────
WX_PAY_APPID=
WX_PAY_MCHID=
WX_PAY_CERT_SERIAL_NO=
WX_PAY_PRIVATE_KEY=
WX_PAY_API_V3_KEY=
WX_PAY_NOTIFY_URL=https://your-domain.example.com/api/v1/mp/payments/wx-notify

# ── 讯飞 AI 配置 ─────────────────────────────────────────────────────────
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=

# ── 文件上传路径 ──────────────────────────────────────────────────────────
UPLOAD_PATH=/app/uploads

# ── 服务端口 ──────────────────────────────────────────────────────────────
BACKEND_PORT=8080
ADMIN_PORT=80

# ── JVM 参数 ──────────────────────────────────────────────────────────────
JAVA_OPTS=-Xms256m -Xmx512m

# ── 监控端口 ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123456
