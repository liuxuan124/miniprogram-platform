# 本地准生产部署环境变量
# 使用时复制为 deploy/.env：
#   Copy-Item deploy\.env.local.example deploy\.env

MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=miniapp
MYSQL_USER=miniapp
MYSQL_PASSWORD=miniapp123456
MYSQL_PORT=3306

REDIS_PASSWORD=redis123456
REDIS_PORT=6379

JWT_SECRET=local-dev-jwt-secret-key-must-be-at-least-256-bits-long
JWT_EXPIRATION=86400000

WX_MINIAPP_APPID=
WX_MINIAPP_SECRET=

WX_PAY_APPID=
WX_PAY_MCHID=
WX_PAY_CERT_SERIAL_NO=
WX_PAY_PRIVATE_KEY=
WX_PAY_API_V3_KEY=
WX_PAY_NOTIFY_URL=http://localhost/api/v1/mp/payments/wx-notify

UPLOAD_PATH=/app/uploads

BACKEND_PORT=8080
ADMIN_PORT=80

JAVA_OPTS=-Xms256m -Xmx512m

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123456
